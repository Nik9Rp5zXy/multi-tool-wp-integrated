# .env.example — Kopyalayıp .env olarak adlandırın ve değerleri doldurun

# Bot Owner telefon numarası (format: numara@c.us)
OWNER_NUMBER="905510395152@c.us"

# Admin numaraları virgülle (birden fazla için: 905xxx@c.us,905yyy@c.us)
ADMIN_NUMBERS="905xxxxxxxxx@c.us"

# Whisper Ses Tanıma Modeli ('tiny', 'base', 'small', 'medium', 'large')
# Not: Bu .ayar komutuyla da değiştirilebilir (kalıcı)
WHISPER_MODEL="small"
